{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Video Course Cards",
  "version": "0.1.0",
  "identifier": "com.videocoursecards.desktop",
  "build": {
    "beforeDevCommand": "powershell -NoProfile -ExecutionPolicy Bypass -File ..\\scripts\\start-tauri-frontend-dev.ps1",
    "devUrl": "http://127.0.0.1:5174",
    "beforeBuildCommand": "npm.cmd run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Video Course Cards",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: http://asset.localhost data: blob:; style-src 'self' 'unsafe-inline'; connect-src 'self' http://127.0.0.1:8001 http://localhost:8001;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/video-course-cards-backend"
    ]
  }
}
