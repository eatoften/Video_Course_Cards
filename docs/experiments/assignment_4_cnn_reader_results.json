  "design_decisions": [
    {
      "choice": "horizontal_stride_4",
      "reason": "Every train and validation sample passed the CTC alignment bound; stride 2 added CPU cost and stride 8 discarded unneeded horizontal detail."
    },
    {
      "choice": "channel_layer_norm",
      "reason": "Normalization is per pixel across channels, so batch peers and right-padding area do not change normalization statistics."
    },
    {
      "choice": "mask_after_every_convolution_block",
      "reason": "A failing padding-invariance test showed later convolutions could propagate padded boundary activations back into valid columns."
    },
    {
      "choice": "no_recurrent_layer",
      "reason": "The future CNN-versus-ViT study should change the visual encoder rather than confound it with a CNN-only BiLSTM."
    },
    {
      "choice": "cpu_runtime",
      "reason": "The installed torch build was CPU-only and the 268-sample formal train set completed in minutes; changing model and runtime together was unnecessary."
    },
    {
      "choice": "separate_training_and_test_commands",
      "reason": "Training code cannot construct a test loader, while test evaluation requires the frozen checkpoint hash and cannot optimize or select a model."
    }
  ],
