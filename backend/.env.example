VCC_LLM_PROVIDER=ollama
VCC_LLM_BASE_URL=http://localhost:11434/v1
VCC_LLM_MODEL=qwen3:4b
VCC_LLM_API_KEY=local
VCC_LLM_TEMPERATURE=0.0
VCC_LLM_MAX_TOKENS=8192
VCC_LLM_TIMEOUT_SECONDS=120

# Local semantic chunking embeddings.
# Leave VCC_EMBEDDING_MODEL_PATH empty to auto-detect a complete local
# Hugging Face cache snapshot.
VCC_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VCC_EMBEDDING_MODEL_PATH=
VCC_EMBEDDING_LOCAL_FILES_ONLY=true
VCC_EMBEDDING_BATCH_SIZE=32
